        "text": "🎤 Voice note received! Processing transcription...\n\n_(This is handled by the Voice Notes workflow)_",
        "additionalFields": {}
      },
      "id": "ack-voice",
      "name": "Ack Voice Note",
      "type": "n8n-nodes-base.telegram",
